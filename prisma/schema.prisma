// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model HiddenFact {
  id              String   @id @default(cuid())
  category        String
  title           String
  severity        String   // critical, high, medium, low
  description     String
  affectedPolicies String[]
  whatToCheck     String
  realCase        String
  example         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([severity])
}

model ClaimCase {
  id          String   @id @default(cuid())
  category    String
  title       String
  status      String   // approved, rejected, partial
  amount      Int
  issue       String
  details     String
  outcome     String
  lesson      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([status])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  savedFacts    String[]
  savedCases    String[]
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  savedQuotes   SavedQuote[]
  chatHistory   ChatHistory[]
  policyScans   PolicyScan[]
  calculations  UserCalculation[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PolicyScan {
  id                String   @id @default(cuid())
  userId            String
  policyName        String
  overallScore      Int
  summary           String?
  redFlags          Json     // Array of { item, severity, description }
  waitingPeriods    Json     // Array of { type, duration, details }
  verdict           String?
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
}

model UserCalculation {
  id                String   @id @default(cuid())
  userId            String
  type              String   // 'HLV', 'TAX', 'ROOM_RENT'
  inputData         Json     // Stores the slider values
  result            Json     // Stores the calculated outputs
  
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
}

// -----------------------------------------------------------------------------
// NEXTAUTH MODELS REQUIRED BY @auth/prisma-adapter
// -----------------------------------------------------------------------------
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -----------------------------------------------------------------------------
// USER DASHBOARD ROADMAP MODELS
// -----------------------------------------------------------------------------
model SavedQuote {
  id          String   @id @default(cuid())
  userId      String
  type        String   // 'term', 'health', 'motor', etc.
  provider    String   // 'HDFC ERGO', 'Max Life', etc.
  premium     Int
  coverAmount Int
  notes       String?
  details     Json?    // Stores specific feature flags or extracted exclusions

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model ChatHistory {
  id          String   @id @default(cuid())
  userId      String
  title       String
  messages    Json     // Array of { role: 'user' | 'assistant', content: string }
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Quote {
  id              String   @id @default(uuid())
  insuranceType   String
  coverageAmount  Int
  applicantAge    Int
  tobaccoUser     Boolean?
  premiumAmount   Float
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([insuranceType])
}

// --- GLOBAL INSURANCE MEGA DATABASE & KNOWLEDGE GRAPH ---

model InsuranceCategory {
  id          String                 @id @default(cuid())
  name        String                 @unique // e.g., "Health Insurance"
  slug        String                 @unique
  subcat      InsuranceSubcategory[]
}

model InsuranceSubcategory {
  id          String         @id @default(cuid())
  name        String         // e.g., "Family Floater"
  categoryId  String
  category    InsuranceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  types       InsuranceType[]
}

model InsuranceType {
  id             String      @id @default(cuid())
  name           String      // e.g., "Senior Citizen Family Floater"
  subcategoryId  String
  subcategory    InsuranceSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  policies       InsurancePolicy[]
  
  // Knowledge Graph Relationships
  relatedTo      TypeRelation[] @relation("RelatedFrom")
  relatedFrom    TypeRelation[] @relation("RelatedTo")
}

model TypeRelation {
  id           String      @id @default(cuid())
  fromId       String
  toId         String
  relationType String      // e.g., "REQUIRES_RIDER", "MUTUALLY_EXCLUSIVE_WITH"
  fromType     InsuranceType @relation("RelatedFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toType       InsuranceType @relation("RelatedTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, relationType])
}

model InsurancePolicy {
  id               String    @id @default(cuid())
  typeId           String
  type             InsuranceType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  providerName     String
  productName      String
  
  // Stored as JSON for dynamic comparison attributes (PolicyBazaar style)
  coverageData     Json      
  eligibilityData  Json
  financialData    Json      // Premiums, limits
  
  benefits         String[]  // Array of benefits
  exclusions       String[]  // Array of exclusions
  
  seoSlug          String    @unique
  createdAt        DateTime  @default(now())
}

// -----------------------------------------------------------------------------
// LEAD GENERATION (PHASE 6)
// -----------------------------------------------------------------------------
model Lead {
  id              String   @id @default(cuid())
  name            String
  email           String
  phone           String
  insuranceType   String
  status          String   @default("NEW") // 'NEW', 'CONTACTED', 'CONVERTED', 'LOST'
  source          String   @default("ORGANIC")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([insuranceType])
}
