{
    "name": "insurance-clarity-nextjs",
    "version": "1.0.0",
    "private": true,
    "packageManager": "npm@11.6.2",
    "engines": {
        "node": "24.x",
        "npm": "11.x"
    },
    "overrides": {
        "axios": "^1.15.0",
        "js-yaml": "^4.1.1"
    },
    "scripts": {
        "dev": "next dev",
        "prebuild": "node scripts/clean-next-build.mjs",
        "build": "node scripts/run-next-build.mjs",
        "analyze": "cross-env ANALYZE=true node scripts/run-next-build.mjs",
        "start": "next start",
        "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 100",
        "theme:audit": "node scripts/theme-audit.mjs",
        "theme:audit:strict": "node scripts/theme-audit.mjs --strict",
        "i18n:audit": "node scripts/i18n-audit.mjs",
        "i18n:audit:strict": "node scripts/i18n-audit.mjs --strict",
        "i18n:locale:audit": "node scripts/i18n-locale-quality-audit.mjs",
        "i18n:locale:audit:strict": "node scripts/i18n-locale-quality-audit.mjs --strict",
        "architecture:audit": "node scripts/architecture-boundary-audit.mjs",
        "architecture:audit:strict": "node scripts/architecture-boundary-audit.mjs --strict",
        "hotspot:audit": "node scripts/hotspot-audit.mjs",
        "hotspot:audit:strict": "node scripts/hotspot-audit.mjs --strict",
        "performance:audit": "node scripts/performance-budget-audit.mjs",
        "performance:audit:strict": "node scripts/performance-budget-audit.mjs --strict",
        "typecheck": "node scripts/clean-next-build.mjs && tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:coverage:critical": "vitest run --coverage --run && node scripts/critical-runtime-coverage.mjs",
        "test:coverage:governed": "vitest run --coverage --run && node scripts/critical-runtime-coverage.mjs && node scripts/shared-surface-coverage.mjs",
        "test:e2e": "playwright test",
        "test:e2e:critical": "npx prisma migrate deploy && cross-env PLAYWRIGHT_FORCE_FRESH_SERVER=1 E2E_TEST_SECRET=local-e2e-test-secret RAZORPAY_WEBHOOK_SECRET=test_secret_for_local_e2e playwright test e2e/payment.spec.ts e2e/auth.spec.ts",
        "test:e2e:ux": "cross-env PLAYWRIGHT_FORCE_FRESH_SERVER=1 E2E_TEST_SECRET=local-e2e-test-secret RAZORPAY_WEBHOOK_SECRET=test_secret_for_local_e2e playwright test e2e/ux-quality.spec.ts",
        "test:e2e:platform": "cross-env PLAYWRIGHT_FORCE_FRESH_SERVER=1 E2E_TEST_SECRET=local-e2e-test-secret RAZORPAY_WEBHOOK_SECRET=test_secret_for_local_e2e playwright test e2e/core-flows.spec.ts e2e/security.spec.ts",
        "test:e2e:seo-accessibility": "cross-env PLAYWRIGHT_FORCE_FRESH_SERVER=1 E2E_TEST_SECRET=local-e2e-test-secret RAZORPAY_WEBHOOK_SECRET=test_secret_for_local_e2e playwright test e2e/seo-accessibility.spec.ts",
        "test:e2e:performance": "cross-env PLAYWRIGHT_FORCE_FRESH_SERVER=1 E2E_TEST_SECRET=local-e2e-test-secret RAZORPAY_WEBHOOK_SECRET=test_secret_for_local_e2e playwright test e2e/performance.spec.ts",
        "test:e2e:ui": "playwright test --ui",
        "check:deploy": "node scripts/pre-deployment-validation.mjs",
        "verify:deploy": "node scripts/post-deployment-verification.mjs",
        "monitor:prod": "node scripts/monitor-production.mjs",
        "ops:branch-protection": "node scripts/ops/set-branch-protection.mjs",
        "security:preflight": "node scripts/security/preflight-env.mjs",
        "security:ensure-razorpay-test-plans": "node scripts/security/ensure-razorpay-test-plans.mjs",
        "check:search": "tsx src/scripts/check-search.ts",
        "db:push": "prisma db push",
        "db:seed": "tsx prisma/seed.ts",
        "db:seed:content": "tsx prisma/seed-content.ts",
        "db:studio": "prisma studio",
        "db:migrate": "prisma migrate dev",
        "db:migrate:prod": "prisma migrate deploy",
        "db:rollout:status": "node scripts/db/rollout-status.mjs",
        "db:rollout:vercel-envs": "node scripts/db/rollout-vercel-envs.mjs",
        "db:search:indexes": "node scripts/db/apply-search-indexes.mjs",
        "db:embeddings:backfill": "tsx src/scripts/backfill-search-embeddings.ts",
        "storage:migrate:object": "tsx src/scripts/migrate-documents-to-s3.ts",
        "storage:migrate:s3": "tsx src/scripts/migrate-documents-to-s3.ts",
        "storage:vercel:status": "node scripts/storage/vercel-s3-status.mjs",
        "storage:vercel:s3-status": "node scripts/storage/vercel-s3-status.mjs",
        "postinstall": "prisma generate",
        "deploy": "echo '❌ DIRECT DEPLOYS BLOCKED. Please git push to main instead.' && exit 1"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1029.0",
        "@google/generative-ai": "^0.24.1",
        "@hookform/resolvers": "^5.2.2",
        "@huggingface/transformers": "^3.8.1",
        "@opentelemetry/api": "^1.9.1",
        "@prisma/client": "^6.19.3",
        "@sanity/icons": "^3.7.4",
        "@sanity/vision": "^5.20.0",
        "@sentry/nextjs": "^10.48.0",
        "@sentry/react": "^10.48.0",
        "@tailwindcss/postcss": "^4.2.2",
        "@types/nodemailer": "^7.0.11",
        "@types/pdf-parse": "^1.1.5",
        "@upstash/qstash": "^2.10.1",
        "@upstash/ratelimit": "^2.0.8",
        "@upstash/redis": "^1.37.0",
        "@vercel/blob": "^2.3.3",
        "@vercel/otel": "^2.1.2",
        "better-auth": "^1.6.2",
        "cloudinary": "^2.9.0",
        "framer-motion": "^12.38.0",
        "lucide-react": "^1.8.0",
        "nanoid": "^5.1.7",
        "next": "^16.2.3",
        "next-intl": "^4.9.1",
        "next-sanity": "^12.2.2",
        "pdf-parse": "^2.4.5",
        "pino": "^10.1.0",
        "pino-pretty": "^13.1.3",
        "posthog-js": "^1.367.0",
        "razorpay": "^2.9.6",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-hook-form": "^7.72.1",
        "recharts": "^3.8.1",
        "resend": "^6.10.0",
        "sanity": "^5.20.0",
        "styled-components": "^6.4.0",
        "tailwind-merge": "^3.5.0",
        "web-vitals": "^5.2.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.1",
        "@next/bundle-analyzer": "^16.2.3",
        "@playwright/test": "^1.59.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^20.19.39",
        "@types/pdfkit": "^0.17.5",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "^4.1.4",
        "autoprefixer": "^10.4.27",
        "cross-env": "^10.1.0",
        "dotenv": "^17.4.1",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.3",
        "jsdom": "^27.4.0",
        "pdfkit": "^0.17.2",
        "pg": "^8.20.0",
        "postcss": "^8.5.9",
        "prisma": "^6.19.3",
        "tailwindcss": "^4.2.2",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.2",
        "vitest": "^4.1.4"
    }
}
