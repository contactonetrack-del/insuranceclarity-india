# InsuranceClarity India — Environment Variables
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in ALL required values below
# 3. NEVER commit .env or .env.local to git — they are in .gitignore
# 4. Generate secrets with: openssl rand -base64 32

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# DATABASE (Prisma — Neon PostgreSQL)
# ===========================================
# Get from: https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Neon requires a DIRECT_URL for connection pooling bypass (migrations)
DIRECT_URL="postgresql://user:password@ep-direct-host/dbname?sslmode=require"

# ===========================================
# AUTHENTICATION (NextAuth.js)
# ===========================================
# REQUIRED: Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth Provider (optional — for social login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ===========================================
# RATE LIMITING (Upstash Redis)
# ===========================================
# Get from: https://console.upstash.com
# Used by middleware for serverless-safe rate limiting
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Local Redis (for BullMQ job queues — development only)
REDIS_URL="redis://localhost:6379"

# ===========================================
# SEARCH (Meilisearch)
# ===========================================
MEILISEARCH_HOST="http://localhost:7700"
# IMPORTANT: Change this from the default — use: openssl rand -hex 32
MEILISEARCH_API_KEY=""

# ===========================================
# ERROR TRACKING (Sentry)
# ===========================================
# Get from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ===========================================
# ANALYTICS (Google Analytics 4)
# ===========================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ===========================================
# EMAIL / SMTP (Transactional emails)
# ===========================================
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@insuranceclarity.in"

# ===========================================
# LOGGING
# ===========================================
# Options: trace | debug | info | warn | error | fatal
LOG_LEVEL="info"

# ===========================================
# PAYMENT GATEWAY (Razorpay — future)
# ===========================================
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
