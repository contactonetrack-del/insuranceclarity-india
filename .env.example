# InsuranceClarity India - Environment Variables
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in all required values below (search for REPLACE_WITH_)
# 3. Never commit .env to git (it is blocked by .gitignore)
# 4. Generate secrets: openssl rand -hex 32
# 5. Run launch checks before deploy: npm run security:preflight

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Async scan processing mode:
# - worker (recommended): dispatches to /api/jobs/document-worker via queue
# - inline: runs analysis in-process
SCAN_PROCESSING_MODE="worker"

# Queue provider:
# - qstash (recommended): fully managed durable queue with retries/DLQ
# - http: direct worker dispatch fallback for local/dev compatibility
QUEUE_PROVIDER="qstash"

# Internal queue secret for worker invocation
# Generate: openssl rand -hex 32
QUEUE_SECRET="REPLACE_WITH_QUEUE_SECRET"

# Upstash QStash (required when QUEUE_PROVIDER=qstash)
# Get from: https://console.upstash.com/qstash
QSTASH_TOKEN="REPLACE_WITH_QSTASH_TOKEN"
QSTASH_CURRENT_SIGNING_KEY="REPLACE_WITH_QSTASH_CURRENT_SIGNING_KEY"
QSTASH_NEXT_SIGNING_KEY="REPLACE_WITH_QSTASH_NEXT_SIGNING_KEY"

# Managed queue delivery tuning
QSTASH_MAX_DELIVERY_RETRIES="5"
QSTASH_RETRY_DELAY="min(60000, 1000 * pow(2, retried))"
QSTASH_DELIVERY_TIMEOUT_SECONDS="60"

# HTTP fallback dispatch tuning (used only when QUEUE_PROVIDER=http)
QUEUE_DISPATCH_MAX_ATTEMPTS="3"
QUEUE_DISPATCH_BASE_DELAY_MS="1200"

# ===========================================
# DATABASE (Prisma - Neon PostgreSQL)
# ===========================================
# Get from: https://console.neon.tech → Project → Connection String
#
# CRITICAL FOR SERVERLESS (Vercel):
# DATABASE_URL must use the POOLER endpoint with PgBouncer parameters.
# Without this, each Vercel serverless cold-start opens a new DB connection,
# exhausting Neon's connection limit (~100 on free tier, ~500 on pro) at
# ~50+ concurrent users → P1001 "Can't reach database" errors in production.
#
# Format:  postgresql://<user>:<pass>@<endpoint>-pooler.<region>.aws.neon.tech/<dbname>?pgbouncer=true&connection_limit=1&sslmode=require
# Note the `-pooler` subdomain — Neon's PgBouncer proxy endpoint.
DATABASE_URL="postgresql://user:password@host-pooler.us-east-1.aws.neon.tech/neondb?pgbouncer=true&connection_limit=1&sslmode=require"
#
# DIRECT_URL is used ONLY by `prisma migrate` and `prisma db push` (DDL operations).
# Use the NON-pooler endpoint here — PgBouncer doesn't support DDL statements.
DIRECT_URL="postgresql://user:password@host.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ===========================================
# AUTHENTICATION (NextAuth.js)
# ===========================================
# Required: openssl rand -base64 32
# Do not use predictable strings or project-name based secrets
NEXTAUTH_SECRET="REPLACE_WITH_STRONG_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Admin email list - comma-separated, gets ADMIN role in JWT
ADMIN_EMAILS="admin@yourdomain.com"

# Google OAuth Provider (social login)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="REPLACE_WITH_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="REPLACE_WITH_GOOGLE_CLIENT_SECRET"

# ===========================================
# RATE LIMITING (Upstash Redis)
# ===========================================
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="REPLACE_WITH_UPSTASH_TOKEN"

# Upstash Redis URL (used for rate limiting via ioredis in dev)
REDIS_URL="rediss://default:TOKEN@your-instance.upstash.io:6379"

# ===========================================
# SEARCH (Meilisearch)
# ===========================================
# Local dev: http://localhost:7700
# Production: set your Meilisearch Cloud HTTPS endpoint
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="REPLACE_WITH_STRONG_KEY"

# ===========================================
# ERROR TRACKING (Sentry)
# ===========================================
# Create project at: https://sentry.io/projects/
NEXT_PUBLIC_SENTRY_DSN="REPLACE_WITH_SENTRY_DSN"
SENTRY_DSN="REPLACE_WITH_SENTRY_DSN"
SENTRY_AUTH_TOKEN="REPLACE_WITH_SENTRY_AUTH_TOKEN"

# ===========================================
# ANALYTICS (Marketing + Product)
# ===========================================
# Google Analytics 4 (marketing / web analytics)
# Get from: https://analytics.google.com > Admin > Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-REPLACE_WITH_YOUR_ID"

# PostHog (product analytics)
# Get from: https://app.posthog.com or your self-hosted workspace
NEXT_PUBLIC_POSTHOG_KEY="phc_REPLACE_WITH_POSTHOG_KEY"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Disable runtime analytics in CI, tests, or emergency rollback scenarios
NEXT_PUBLIC_DISABLE_RUNTIME_ANALYTICS="false"

# ===========================================
# OBSERVABILITY (Vercel OpenTelemetry)
# ===========================================
OTEL_SERVICE_NAME="insurance-clarity-nextjs"
OTEL_ENABLED="true"

# ===========================================
# EMAIL (Resend)
# ===========================================
# API key: https://resend.com/api-keys
# Verify domain: https://resend.com/domains
RESEND_API_KEY="REPLACE_WITH_RESEND_API_KEY"
EMAIL_FROM="Insurance Clarity <noreply@yourdomain.com>"

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL="info"

# ===========================================
# REFERRALS
# ===========================================
# Used to generate stable user referral codes.
REFERRAL_CODE_SECRET="REPLACE_WITH_REFERRAL_SECRET"

# ===========================================
# AI ENGINE
# ===========================================
# Gemini: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="REPLACE_WITH_GEMINI_KEY"

# ===========================================
# PAYMENT GATEWAY (Razorpay)
# ===========================================
# Use `test` for current development and controlled QA.
# Switch to `live` before production launch.
RAZORPAY_MODE="test"

# Dashboard: https://dashboard.razorpay.com/app/keys
# In test mode use rzp_test_* keys; in live mode use rzp_live_* keys.
RAZORPAY_KEY_ID="rzp_test_REPLACE_WITH_KEY_ID"
RAZORPAY_KEY_SECRET="REPLACE_WITH_RAZORPAY_SECRET"

# Must exactly match RAZORPAY_KEY_ID
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_REPLACE_WITH_KEY_ID"

# Webhook secret (Razorpay Dashboard > Webhooks)
RAZORPAY_WEBHOOK_SECRET="REPLACE_WITH_WEBHOOK_SECRET"

# Subscription plan IDs (Dashboard > Subscriptions > Plans)
# Keep test plans while RAZORPAY_MODE=test, switch to live plans for launch
# Note: these must be `plan_...` IDs, not `rzp_...` key IDs
RAZORPAY_PLAN_ID_PRO="plan_REPLACE_WITH_PRO_ID"
RAZORPAY_PLAN_ID_ENTERPRISE="plan_REPLACE_WITH_ENTERPRISE_ID"

# Temporary bypass for preflight plan-id validation when Razorpay account is under review.
# Set to true only if owner explicitly accepts deferred plan configuration.
RAZORPAY_SKIP_PLAN_VALIDATION="false"

# ===========================================
# FILE STORAGE (Cloudinary)
# ===========================================
# Dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="REPLACE_WITH_CLOUD_NAME"
CLOUDINARY_API_KEY="REPLACE_WITH_API_KEY"
CLOUDINARY_API_SECRET="REPLACE_WITH_API_SECRET"

# ===========================================
# CRON JOB SECURITY
# ===========================================
# Generate: openssl rand -hex 32
CRON_SECRET="REPLACE_WITH_CRON_SECRET"
